  def Discriminator(self,input_1):
    Efficient=ResNet101V2(include_top=False,weights="imagenet",
    input_tensor=input_1,
    input_shape=None,
    pooling=None,
    classes=1000)
    #Efficient.summary()
    for layer in Efficient.layers[:-100]:
      layer.trainable = False
    #post_relu resnet101v2 conv5_block3_out EfficientNetB7 top_activation Xception block14_sepconv2_act
    x = Flatten(name="flatten")(Efficient.get_layer('post_relu').output)
    x = BatchNormalization() (x)
    x = Dense(512, activation="relu", name="layer1")(x)
    x = BatchNormalization() (x)
    x = Dropout(0.5) (x)
    x = Dense(512, activation="relu", name="layer2")(x)
    x = BatchNormalization() (x)
    x = Dropout(0.3) (x)
    x = Dense(64, activation="sigmoid", name="layer3")(x)
    self.ResModel = training.Model(input_1, x,)

  def Contrastive(self,input_1,input_2,input_3):
    #input_1,input_2=input
    self.Discriminator(input_1)

    femodel1=tf.cast(self.ResModel(input_1),tf.float32) #anchor
    femodel2=tf.cast(self.ResModel(input_2),tf.float32) #positive
    femodel3=tf.cast(self.ResModel(input_3),tf.float32) #negative
    #y=Input(shape=(1))
    #merge_layer = Dot(1,normalize=True) ([femodel1,femodel2])
    ED_AP= Lambda(self.euclidean_distance)([femodel1,femodel2])
    ED_AN= Lambda(self.euclidean_distance)([femodel1,femodel3])
    #loss_layer= self.contrastive_loss(ED_AP,ED_AN)
    #normal_layer = BatchNormalization(name='normal')(merge_layer)
    #output_layer = Dense(1, activation="sigmoid",name='last')(normal_layer)
    #self.siamese = Model(inputs=[(input_1, input_2),y], outputs=output_layer)
    self.Siamese_model = Model(inputs=[input_1,input_2,input_3], outputs=(ED_AP,ED_AN))
    self.Siamese_model.compile(loss=self.loss(margin=1), optimizer=tf.keras.optimizers.Adam(0.0001))
